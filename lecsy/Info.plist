<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSMicrophoneUsageDescription</key>
	<string>Lecsy uses the microphone to record your lectures. Audio is transcribed on your device by default. If your organization has enabled cloud transcription, audio may be processed transiently by our subprocessor Deepgram and is never stored by Lecsy. You can stop recording at any time.</string>
	<key>SUPABASE_ANON_KEY</key>
	<string>$(SUPABASE_ANON_KEY)</string>
	<key>SUPABASE_URL</key>
	<string>$(SUPABASE_URL)</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.takumiNittono.lecsy</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>lecsy</string>
			</array>
		</dict>
	</array>
	<key>UISupportsMultipleScenes</key>
	<false/>
</dict>
</plist>
