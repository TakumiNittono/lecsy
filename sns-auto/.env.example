# ---------- X API v2 (OAuth 1.0a user context) ----------
# https://developer.x.com/en/portal/dashboard
# アプリ → Keys and tokens → Consumer Keys / Access Token
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ---------- OpenAI API ----------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---------- Slack 通知 ----------
# api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=
SLACK_NOTIFY_SUCCESS=false

# ---------- Kill switch ----------
# true にすると sns-run.mjs が即終了 (何も投稿しない)
SNS_AUTO_DISABLED=false
